PORT=5000

# MongoDB - use this for Docker (mongo is the service name)
MONGO_URI=mongodb://mongo:27017/onlinestore

# For local dev without Docker, use:
# MONGO_URI=mongodb://127.0.0.1:27017/onlinestore

JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret

# Optional: email (for forgot password etc.)
# EMAIL_USER=yourgmail@gmail.com
# EMAIL_PASS=your_gmail_app_password
